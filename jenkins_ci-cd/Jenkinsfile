pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "satheesh/devops-app"
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/Satheeshshyam/Devops.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t satheesh/devops-app -f jenkins_ci-cd/Dockerfile .'
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([string(credentialsId: 'dockerhub-pass', variable: 'PASS')]) {
                    sh '''
                    echo $PASS | docker login -u nesa24 --password-stdin
                    docker push $DOCKER_IMAGE
                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f kubernetes/deployment.yaml'
            }
        }

    }
}
